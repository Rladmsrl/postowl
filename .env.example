# PostOwl Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (overrides config.yaml)
# POSTOWL_LLM__BASE_URL=https://api.openai.com/v1
# POSTOWL_LLM__API_KEY=sk-xxx
# POSTOWL_LLM__CHAT_MODEL=gpt-4o-mini
# POSTOWL_LLM__EMBEDDING_MODEL=text-embedding-3-small

# Telegram Bot
# POSTOWL_TELEGRAM__BOT_TOKEN=123456:ABC-DEF
# POSTOWL_TELEGRAM__ALLOWED_USER_IDS=[123456,789012]
